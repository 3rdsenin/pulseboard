# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development                   # development | staging | production
PORT=3001                              # API server port
WORKER_CONCURRENCY=5                   # BullMQ concurrent jobs per worker process
LOG_LEVEL=info                         # pino log level: trace|debug|info|warn|error

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pulseboard:changeme@localhost:5432/pulseboard
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@host:6379  (with auth for production)

# ── Authentication ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_32_byte_hex   # openssl rand -hex 32
JWT_REFRESH_SECRET=replace_with_32_byte_hex  # different from access secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Credential Encryption ─────────────────────────────────────────────
ENCRYPTION_KEY=replace_with_64_char_hex      # openssl rand -hex 32
# If ENCRYPTION_KEY is lost, all integration credentials must be re-entered.
# In production: load from AWS Secrets Manager, not this file.

# ── GitHub OAuth (for GitHub login) ───────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── Application ───────────────────────────────────────────────────────
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ── Email [optional — required for invite emails and sync failure alerts] ──
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# EMAIL_FROM=noreply@yourdomain.com

# ── AWS (cloud deployment only) ───────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:...
